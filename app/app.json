{
  "expo": {
    "name": "Chronos Lens",
    "owner": "majikfraug",
    "slug": "chronos-lens",
    "scheme": "chronoslens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0E0B",
    "ios": {
      "bundleIdentifier": "com.chronoslens.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "The Lens tracks your real-world position to reveal the field map as you walk and to log where artifacts were surveyed. Position data never leaves this device.",
        "NSCameraUsageDescription": "The Lens renders the camera feed as a dithered scan to classify artifacts and features you point it at. No images leave this device.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.chronoslens.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0E0B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "The Lens tracks your real-world position to reveal the field map as you walk. Position data never leaves this device."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "The Lens renders the camera feed as a dithered scan to classify artifacts and features you point it at. No images leave this device."
        }
      ],
      "expo-splash-screen",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "b5914f4b-4dfc-40f6-907a-bf62e5e1e0c8"
      }
    }
  }
}
