{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    },
    "playtest": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_ACCELERATED_MATURATION": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
